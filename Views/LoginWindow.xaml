<Window x:Class="VRChatLotteryTool.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VRChat ログイン"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#EAEAEA"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background"      Value="#0D1B3A"/>
      <Setter Property="Foreground"      Value="#EAEAEA"/>
      <Setter Property="BorderBrush"     Value="#2A4080"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,6"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="CaretBrush"      Value="#EAEAEA"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="#E94560"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="PasswordBox">
      <Setter Property="Background"      Value="#0D1B3A"/>
      <Setter Property="Foreground"      Value="#EAEAEA"/>
      <Setter Property="BorderBrush"     Value="#2A4080"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="8,6"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="CaretBrush"      Value="#EAEAEA"/>
    </Style>
  </Window.Resources>

  <!-- StackPanel で縦積み: SizeToContent="Height" で自動調整 -->
  <StackPanel Margin="32" Width="356">

    <!-- タイトル -->
    <TextBlock Text="🎲" FontSize="32" HorizontalAlignment="Center" Margin="0,24,0,8"/>
    <TextBlock Text="VRChat Lottery Tool" FontSize="18" FontWeight="Bold"
               HorizontalAlignment="Center"/>
    <TextBlock Text="VRChat アカウントでログインしてください"
               FontSize="11" Foreground="#A0A0B0"
               HorizontalAlignment="Center" Margin="0,6,0,24"/>

    <!-- ── ログインフォーム ── -->
    <StackPanel x:Name="LoginPanel">
      <TextBlock Text="ユーザー名 または メールアドレス"
                 FontSize="11" Foreground="#A0A0B0" Margin="0,0,0,4"/>
      <TextBox x:Name="UsernameBox" Margin="0,0,0,12" KeyDown="InputKeyDown"/>

      <TextBlock Text="パスワード"
                 FontSize="11" Foreground="#A0A0B0" Margin="0,0,0,4"/>
      <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12" KeyDown="InputKeyDown"/>

      <CheckBox x:Name="RememberCheck"
                Content="ログイン情報を保存する"
                Foreground="#A0A0B0" FontSize="11"
                Margin="0,0,0,0"/>
    </StackPanel>

    <!-- ── 2FA フォーム（初期非表示）── -->
    <StackPanel x:Name="TwoFaPanel" Visibility="Collapsed">
      <TextBlock Text="2要素認証コード"
                 FontSize="11" Foreground="#A0A0B0" Margin="0,0,0,4"/>
      <TextBox x:Name="TwoFaCodeBox" Margin="0,0,0,8" MaxLength="6" KeyDown="InputKeyDown"/>
      <TextBlock x:Name="TwoFaHintText"
                 FontSize="11" Foreground="#A0A0B0"
                 TextWrapping="Wrap"/>
    </StackPanel>

    <!-- エラーメッセージ: 常に領域確保 (Visibility=Hidden/Visible で高さを保つ) -->
    <Border Margin="0,12,0,0" MinHeight="36">
      <TextBlock x:Name="ErrorText"
                 Foreground="#F44336" FontSize="12"
                 TextWrapping="Wrap"
                 Visibility="Collapsed"/>
    </Border>

    <!-- ボタン -->
    <Button x:Name="LoginButton"
            Content="ログイン"
            Height="42" Margin="0,4,0,0"
            FontSize="14" FontWeight="SemiBold"
            Foreground="White" BorderThickness="0"
            Cursor="Hand" Click="LoginButtonClick">
      <Button.Style>
        <Style TargetType="Button">
          <Setter Property="Background" Value="#E94560"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="Button">
                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                  </Trigger>
                  <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Button.Style>
    </Button>

    <TextBlock x:Name="StatusText"
               Text="" FontSize="11" Foreground="#A0A0B0"
               HorizontalAlignment="Center" Margin="0,10,0,24"/>
  </StackPanel>
</Window>
