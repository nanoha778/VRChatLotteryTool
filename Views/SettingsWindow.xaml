<Window x:Class="VRChatLotteryTool.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="全般設定"
        Width="480" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDark}">

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="全般設定" FontSize="16" FontWeight="Bold"
               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- テーマ -->
        <TextBlock Text="外観" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
        <Border Style="{StaticResource Panel}" Margin="0,0,0,20">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="テーマ" Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
              <TextBlock Text="ダークモード / ライトモードを切り替えます"
                         Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <ToggleButton Grid.Column="1" IsChecked="{Binding IsDarkTheme}"
                          Width="120" Height="32" Cursor="Hand" BorderThickness="0">
              <ToggleButton.Style>
                <Style TargetType="ToggleButton">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="16"
                                Background="{DynamicResource SecondaryBtn}" Padding="12,0">
                          <TextBlock x:Name="txt" Text="🌙 ダーク" Foreground="White"
                                     FontSize="12" FontWeight="SemiBold"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="bd"  Property="Background" Value="#E0A020"/>
                            <Setter TargetName="txt" Property="Text"       Value="☀️ ライト"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ToggleButton.Style>
            </ToggleButton>
          </Grid>
        </Border>

        <!-- アカウント情報 -->
        <TextBlock Text="アカウント" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
        <Border Style="{StaticResource Panel}" Margin="0,0,0,20">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="10"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="10"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="ユーザー名"
                       Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoginUserName}"
                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="ワールド"
                       Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentWorldName}"
                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="4" Grid.Column="0" Text="インスタンスID"
                       Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentInstanceId}"
                       Foreground="#6080A0" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- データ -->
        <TextBlock Text="データ" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
        <Border Style="{StaticResource Panel}">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="データフォルダを開く"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                <TextBlock Text="%AppData%\VRChatLotteryTool"
                           Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,2,0,0"/>
              </StackPanel>
              <Button Grid.Column="1" Content="開く" Style="{StaticResource SecondaryButton}"
                      Padding="16,6" Click="OpenDataFolder"/>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Button Grid.Row="2" Content="閉じる" Style="{StaticResource SecondaryButton}"
            HorizontalAlignment="Right" Margin="0,16,0,0" Padding="24,8"
            Click="CloseClick"/>
  </Grid>
</Window>
